{
  "info": {
    "name": "Smart Campus - Member 3 Ticketing Module",
    "_postman_id": "4b2fbb87-df02-47d3-bbb5-5a99787f35b4",
    "description": "Incident Tickets + Attachments + Technician Updates API collection for IT3030 PAF 2026.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Ticket",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Email", "value": "{{userEmail}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Projector in Lab 3 not working\",\n  \"category\": \"EQUIPMENT\",\n  \"description\": \"Projector is not turning on for 9:00 AM lecture.\",\n  \"priority\": \"HIGH\",\n  \"preferredContactDetails\": \"0771234567\",\n  \"relatedResource\": \"Lab 3 Projector\",\n  \"relatedLocation\": \"Engineering Building - Lab 3\"\n}"
        },
        "url": "{{baseUrl}}/api/tickets"
      }
    },
    {
      "name": "List My/Visible Tickets",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-User-Email", "value": "{{userEmail}}" }
        ],
        "url": "{{baseUrl}}/api/tickets"
      }
    },
    {
      "name": "Get Ticket By ID",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-User-Email", "value": "{{userEmail}}" }
        ],
        "url": "{{baseUrl}}/api/tickets/{{ticketId}}"
      }
    },
    {
      "name": "Upload Ticket Attachments (max 3 images)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "X-User-Email", "value": "{{userEmail}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "files", "type": "file", "src": [] }
          ]
        },
        "url": "{{baseUrl}}/api/tickets/{{ticketId}}/attachments"
      }
    },
    {
      "name": "Assign Technician (ADMIN)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Email", "value": "{{adminEmail}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"technicianEmail\": \"{{technicianEmail}}\"\n}"
        },
        "url": "{{baseUrl}}/api/tickets/{{ticketId}}/assign"
      }
    },
    {
      "name": "Move Ticket To IN_PROGRESS (Assigned TECHNICIAN/ADMIN)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Email", "value": "{{technicianEmail}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}"
        },
        "url": "{{baseUrl}}/api/tickets/{{ticketId}}/status"
      }
    },
    {
      "name": "Add Progress Update",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Email", "value": "{{technicianEmail}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"updateText\": \"Checked cable and power adapter. Waiting for replacement bulb.\"\n}"
        },
        "url": "{{baseUrl}}/api/tickets/{{ticketId}}/progress-updates"
      }
    },
    {
      "name": "Add Resolution Note",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Email", "value": "{{technicianEmail}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"resolutionNote\": \"Replaced projector lamp and verified HDMI output.\"\n}"
        },
        "url": "{{baseUrl}}/api/tickets/{{ticketId}}/resolution"
      }
    },
    {
      "name": "Move Ticket To RESOLVED",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Email", "value": "{{technicianEmail}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"RESOLVED\"\n}"
        },
        "url": "{{baseUrl}}/api/tickets/{{ticketId}}/status"
      }
    },
    {
      "name": "Close Ticket (ADMIN)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Email", "value": "{{adminEmail}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"CLOSED\"\n}"
        },
        "url": "{{baseUrl}}/api/tickets/{{ticketId}}/status"
      }
    },
    {
      "name": "Reject Ticket With Reason (ADMIN)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Email", "value": "{{adminEmail}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"Issue is duplicate of Ticket #22 and merged.\"\n}"
        },
        "url": "{{baseUrl}}/api/tickets/{{ticketId}}/reject"
      }
    },
    {
      "name": "Add Comment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Email", "value": "{{userEmail}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"commentText\": \"Please prioritize this before tomorrow morning lecture.\"\n}"
        },
        "url": "{{baseUrl}}/api/tickets/{{ticketId}}/comments"
      }
    },
    {
      "name": "Get My Notifications",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-User-Email", "value": "{{userEmail}}" }
        ],
        "url": "{{baseUrl}}/api/tickets/notifications"
      }
    },
    {
      "name": "Mark Notification As Read",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "X-User-Email", "value": "{{userEmail}}" }
        ],
        "url": "{{baseUrl}}/api/tickets/notifications/{{notificationId}}/read"
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8089" },
    { "key": "ticketId", "value": "1" },
    { "key": "notificationId", "value": "1" },
    { "key": "userEmail", "value": "student1@sliit.lk" },
    { "key": "technicianEmail", "value": "tech1@sliit.lk" },
    { "key": "adminEmail", "value": "admin@sliit.lk" }
  ]
}
